# AI People Reader V2 - Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env (it contains secrets).

# ---- Required: AWS S3 ----
AWS_BUCKET=your-bucket-name
# or S3_BUCKET=your-bucket-name

AWS_REGION=ap-southeast-1

# ---- MediaPipe (report + video workers) ----
# Headless servers: Render uses xvfb-run + libgl1 (see render.yaml). If you run report_worker locally
# on macOS without a GUI and see NSOpenGLPixelFormat / kGpuService errors, use a Linux host or run under
# a virtual display. To allow GPU paths on a normal desktop: MEDIAPIPE_USE_GPU=1
# MEDIAPIPE_USE_GPU=1

# ---- Movement type ----
# Classification uses built-in TYPE_TEMPLATES in movement_type_classifier.py only (no S3 calibration).

# ---- Optional: App ----
APP_LOCAL_TIMEZONE=Asia/Bangkok
# Multipage: files in pages/*.py also call load_dotenv(repo/.env) so AWS_BUCKET works when
# you open a page directly. In Admin org settings, default_page uses keys: ttb | lpa (see TTB / LPA pages).
# Admin defaults new orgs to PDF for reports (better for email attachments); TTB/LPA use pdf if no org row in S3.

# ---- Debug (ดู S3 keys ที่พบในหน้า download) ----
# DEBUG_DOWNLOAD=1

# ---- Optional: Email (SES / SMTP) ----
# For report worker and email notifications
SES_REGION=ap-southeast-1
SES_FROM_EMAIL=your-verified-ses-email@example.com
SES_CONFIGURATION_SET=your-config-set-name

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=your-from@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Internal copies for every skeleton/dots/report notification email (server-side; not shown in the app).
# Default in code includes ops addresses; set empty to disable: INTERNAL_ANALYSIS_NOTIFY_EMAILS=
# INTERNAL_ANALYSIS_NOTIFY_EMAILS=rungnapa@imagematters.at,petchpat@gmail.com

# Report worker: poll jobs/email_pending/ on a background thread while a long report job runs (faster mail).
# Set to 0 to disable. EMAIL_QUEUE_BACKGROUND_MAX_ITEMS=25 (default) per tick.
# EMAIL_PENDING_BACKGROUND_POLL_SECONDS=10

# Report worker: wait for skeleton.mp4 before emailing PDFs; one email with reports + skeleton link. false = old behavior.
# DEFER_REPORT_EMAIL_UNTIL_SKELETON=true

# ---- Optional: Analysis defaults ----
SAMPLE_FPS=5
MAX_FRAMES=300
ANALYSIS_MODE=real

# ---- Optional: Job recovery ----
# PENDING_STALE_HOURS=2  # Move to failed if input video missing for this many hours

# ---- Video worker (worker.py) ----
# How many jobs/pending/*.json keys to scan per poll. If the queue is huge, dots jobs can sort
# after many skeleton/report JSON files; raise this (e.g. 20000) if dots videos never complete.
# Video worker (worker.py and src/worker.py on Render): scan this many pending *.json keys before
# picking dots/skeleton; needed when many report jobs sort before video jobs in jobs/pending/.
# WORKER_PENDING_MAX_SCAN=10000

# ---- Skeleton video (worker.py) ----
# Longest side (px) sent to MediaPipe; 0 = full resolution (slow on 4K). Default 1280 ≈ 1:1 overlay.
# SKELETON_POSE_MAX_SIDE=1280
# MediaPipe pose model: 0 / 1 / 2 (2 = heavier, often tracks better)
# SKELETON_MODEL_COMPLEXITY=2

# ---- Optional: SkillLane auth ----
# SKILLLANE_AUTH_SALT=your-random-secret  # Salt for password hashing (set in production)
